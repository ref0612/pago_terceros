# ══════════════════════════════════════════════
# PULLMAN PAGO EMPRESARIOS — Variables de entorno
# Copiar este archivo como .env (nunca subir .env a git)
# ══════════════════════════════════════════════

# ── Credenciales de la app (login del dashboard) ──────────
# Usuario y contraseña que usará tu equipo para iniciar sesión
APP_USER=admin
APP_PASS=cambia_esta_clave_por_una_segura

# Secreto para firmar los JWT de sesión (mínimo 32 caracteres aleatorios)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=genera_un_secreto_largo_y_aleatorio_aqui

# ── Credenciales de Konnect Pro (NUNCA van al front) ──────
# Bearer token de la API de Konnect (el que antes estaba en script.js)
KONNECT_BEARER_TOKEN=eyJhbGciOiJIUzI1NiJ9...

# x-api-key de Konnect
KONNECT_API_KEY=QHH79qF2fsWEx98pvNeZpQ

# ── CORS (producción) ─────────────────────────────────────
# Lista separada por comas de los dominios autorizados
# Dejar vacío en desarrollo local
ALLOWED_ORIGINS=https://pullman-pago-empresarios.vercel.app,https://pullman-pago-empresarios.onrender.com

# ── Entorno ───────────────────────────────────────────────
NODE_ENV=production
