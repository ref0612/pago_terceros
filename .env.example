# ══════════════════════════════════════════════
# PULLMAN PAGO EMPRESARIOS — Variables de entorno
# ══════════════════════════════════════════════

# ── Secreto JWT ───────────────────────────────
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=genera_un_secreto_largo_aqui

# ── Usuario SUPERVISOR (aprueba/rechaza pagos) ─
SUPERVISOR_USER=supervisor
SUPERVISOR_PASS=cambia_esta_clave

# ── Usuario CONTABLE (ve y deposita pagos) ────
CONTABLE_USER=contable
CONTABLE_PASS=cambia_esta_clave

# ── Credenciales Konnect Pro ──────────────────
KONNECT_BEARER_TOKEN=eyJhbGciOiJIUzI1NiJ9...
KONNECT_API_KEY=QHH79qF2fsWEx98pvNeZpQ

# ── Vercel KV (Redis para aprobaciones) ───────
# Se generan automáticamente al vincular un KV store en Vercel
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Entorno ───────────────────────────────────
NODE_ENV=production

# ── API Aramco (cargos por empresario por día) ────────────
# TODO: completar cuando el equipo tenga los endpoints listos
ARAMCO_API_URL=
ARAMCO_API_TOKEN=
